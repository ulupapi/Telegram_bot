TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Опционально: фиксированная цель (чат/ветка).
# По умолчанию бот работает в multi-chat режиме и собирает контекст
# в том чате/ветке, где его вызвали.
TARGET_CHAT_ID=
TARGET_TOPIC_ID=
# Включите, если нужен строго один chat/topic из TARGET_*.
STRICT_TARGET_SCOPE=false

LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Для OpenAI вместо Gemini:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=

# Для Amvera LLM:
# LLM_PROVIDER=amvera
# AMVERA_LLM_API_KEY=your_amvera_llm_api_key
# AMVERA_LLM_BASE_URL=https://your-amvera-llm-endpoint/v1
# AMVERA_LLM_MODEL=gpt-5
# AMVERA_LLM_FALLBACK_MODEL=gpt-4.1

# База данных:
# DB_BACKEND=auto|sqlite|postgres
DB_BACKEND=auto
POSTGRES_DSN=

SQLITE_PATH=data/bot.db
CONTEXT_MESSAGES_LIMIT=120
LLM_TIMEOUT_SECONDS=120

# Авто-сводка 2 раза в день:
SCHEDULE_ENABLED=0
SUMMARY_MORNING_TIME=09:00
SUMMARY_EVENING_TIME=18:00
SCHEDULE_TIMEZONE=Europe/Moscow
